generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ------------------------------------------------------------------ */
/* Auth.js (NextAuth v5) models — see authjs.dev/getting-started/adapters/prisma */
/* ------------------------------------------------------------------ */

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  memberships    TripMember[]
  invitesCreated Invite[]
  expensesPaid    Expense[]      @relation("ExpensesPaid")
  expenseSplits   ExpenseSplit[]
  settlementsFrom Settlement[]   @relation("SettlementsFrom")
  settlementsTo   Settlement[]   @relation("SettlementsTo")
  availability    AvailabilityDay[]
  packingItems    PackingItem[]     @relation("PackingAssignee")
  personalPacking PackingItem[]     @relation("PersonalPackingItems")
  ideasCreated    ActivityIdea[]    @relation("IdeasCreated")
  activityVotes   ActivityVote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/* ------------------------------------------------------------------ */
/* Travel planner domain models                                        */
/* ------------------------------------------------------------------ */

model Trip {
  id          String    @id @default(cuid())
  title       String
  destination String
  // Null while the group is still picking dates via the availability poll.
  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date
  // Availability-poll candidate window and desired trip length; set when the
  // trip is created without fixed dates.
  windowStart  DateTime? @db.Date
  windowEnd    DateTime? @db.Date
  durationDays Int?
  totalBudget Decimal? @db.Decimal(12, 2)
  // Single currency per trip: expense splitting and balances assume it.
  currency    String   @default("EUR")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      TripMember[]
  days         TripDay[]
  invites      Invite[]
  expenses     Expense[]
  settlements  Settlement[]
  availability AvailabilityDay[]
  packingItems PackingItem[]
  packingTemplates PackingTemplate[]
  ideas        ActivityIdea[]
}

enum TripRole {
  OWNER
  EDITOR
  VIEWER
}

model TripMember {
  id        String   @id @default(cuid())
  role      TripRole @default(VIEWER)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // A user can only be a member of a trip once
  @@unique([userId, tripId])
  @@index([tripId])
  @@index([userId])
}

model Invite {
  id        String   @id @default(cuid())
  token     String   @unique
  role      TripRole @default(VIEWER)
  expiresAt DateTime
  createdAt DateTime @default(now())

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  createdBy String
  creator   User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([tripId])
}

/* ------------------------------------------------------------------ */
/* Expense splitting — all money stored as integer cents               */
/* ------------------------------------------------------------------ */

enum ExpenseCategory {
  FOOD
  TRANSPORT
  LODGING
  ACTIVITY
  SHOPPING
  OTHER
}

model Expense {
  id          String          @id @default(cuid())
  description String
  amountCents Int
  currency    String
  category    ExpenseCategory @default(OTHER)
  date        DateTime        @db.Date
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  paidById String
  paidBy   User   @relation("ExpensesPaid", fields: [paidById], references: [id], onDelete: Cascade)

  splits ExpenseSplit[]

  @@index([tripId])
  @@index([paidById])
}

model ExpenseSplit {
  id          String @id @default(cuid())
  amountCents Int

  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One share per participant per expense
  @@unique([expenseId, userId])
  @@index([userId])
}

model Settlement {
  id          String   @id @default(cuid())
  amountCents Int
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  fromUserId String
  fromUser   User   @relation("SettlementsFrom", fields: [fromUserId], references: [id], onDelete: Cascade)

  toUserId String
  toUser   User   @relation("SettlementsTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// One row per (member, day) the member is available; absence = unavailable.
model AvailabilityDay {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId, date])
  @@index([tripId])
}

model TripDay {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  activities Activity[]

  // A trip can only have one entry per calendar day
  @@unique([tripId, date])
  @@index([tripId])
}

model Activity {
  id           String    @id @default(cuid())
  title        String
  description  String?
  time         DateTime?
  locationName String?
  latitude     Float?
  longitude    Float?
  cost         Decimal?  @db.Decimal(12, 2)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tripDayId String
  tripDay   TripDay @relation(fields: [tripDayId], references: [id], onDelete: Cascade)

  @@index([tripDayId])
}

/* ------------------------------------------------------------------ */
/* Activity ideas — a voting pool that feeds the itinerary             */
/* ------------------------------------------------------------------ */

model ActivityIdea {
  id            String    @id @default(cuid())
  title         String
  description   String?
  locationName  String?
  // External reference (booking page, review site, …).
  link          String?
  estimatedCost Decimal?  @db.Decimal(12, 2)
  // Set when the idea has been added to the itinerary.
  promotedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // Proposer; SetNull so ideas survive when the member leaves.
  createdById String?
  createdBy   User?   @relation("IdeasCreated", fields: [createdById], references: [id], onDelete: SetNull)

  votes ActivityVote[]

  @@index([tripId])
}

// Row present = user is interested. One vote per member per idea.
model ActivityVote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  ideaId String
  idea   ActivityIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
  @@index([userId])
}

/* ------------------------------------------------------------------ */
/* Packing list — one shared checklist per trip                        */
/* ------------------------------------------------------------------ */

enum PackingCategory {
  GEAR
  CLOTHING
  TOILETRIES
  ELECTRONICS
  DOCUMENTS
  FOOD
  OTHER
}

model PackingItem {
  id        String          @id @default(cuid())
  name      String
  category  PackingCategory @default(OTHER)
  packed    Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // Optional member bringing the item; SetNull so a shared item survives if
  // the assigned member is later removed from the trip.
  assigneeId String?
  assignee   User?   @relation("PackingAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  // Null = shared trip item; set = private item on that member's personal
  // list. Cascade so personal items don't outlive (and leak from) their owner.
  ownerId String?
  owner   User?   @relation("PersonalPackingItems", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([tripId, ownerId])
  @@index([assigneeId])
}

// A reusable packing list any member can import into their personal
// checklist. Built-in templates live in code (lib/packing-templates.ts);
// these rows are the custom ones OWNER/EDITOR members create per trip.
model PackingTemplate {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  items PackingTemplateItem[]

  @@index([tripId])
}

model PackingTemplateItem {
  id       String          @id @default(cuid())
  name     String
  category PackingCategory @default(OTHER)

  templateId String
  template   PackingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}
