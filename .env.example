# Copy to .env and fill in. See README.md for setup details.

# PostgreSQL connection string
DATABASE_URL="postgresql://USER@localhost:5432/travel_app"

# Auth.js session encryption secret — generate with: npx auth secret
# (or: openssl rand -base64 32)
AUTH_SECRET=""

# Google OAuth credentials — https://console.cloud.google.com/apis/credentials
# OAuth client ID → Web application → authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
